{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vet.example/schema/authority-decision.schema.json",
  "type": "object",
  "properties": {
    "authority_decision_id": { "type": "string" },
    "object_id": { "type": "string" },
    "schema_version": { "type": "string" },
    "canonical_digest": { "type": "object" },
    "lifecycle_status": { "type": "string", "enum": ["active", "stale", "revoked", "migrated", "unknown"] },
    "policy_id": { "type": "string" },
    "action": { "type": "string" },
    "decision": { "type": "string", "enum": ["allow", "deny", "quarantine", "residualize"] },
    "deny_by_default": { "const": true },
    "linked_certification_records": { "type": "array", "items": { "type": "string" } },
    "auth_inputs_ref": { "type": "string" },
    "required_certification_components": { "type": "array", "items": { "type": "string" } },
    "required_support_refs": { "type": "array", "items": { "type": "string" } },
    "support_judgment_refs": { "type": "array", "items": { "type": "string" } },
    "aggregate_judgment_ref": { "type": "string" },
    "cex_closed_judgment_refs": { "type": "array", "items": { "type": "string" } },
    "soundgap_refs": { "type": "array", "items": { "type": "string" } },
    "scope_action_match": { "type": "string" },
    "required_human_assessment_roles": { "type": "array", "items": { "type": "string" } },
    "required_tool_assessment_roles": { "type": "array", "items": { "type": "string" } },
    "rollback_hooks_required": { "type": "array", "items": { "type": "string" } },
    "expiry": { "type": "string" },
    "revocation_hooks": { "type": "array", "items": { "type": "string" } },
    "tightening_conditions": { "type": "array", "items": { "type": "string" } },
    "delegation_basis": { "type": "array", "items": { "type": "string" } },
    "migration_witness_ref": { "type": "string" },
    "sandbox_required": { "type": "boolean" },
    "sandbox_status": { "type": "string" },
    "sandbox_waiver_residuals": { "type": "array", "items": { "type": "string" } },
    "residual_gates": { "type": "array", "items": { "type": "string" } },
    "ledger_event_refs": { "type": "array", "items": { "type": "string" } },
    "provenance": { "type": "array", "items": { "type": "string" } }
  },
  "required": [
    "authority_decision_id",
    "object_id",
    "schema_version",
    "canonical_digest",
    "lifecycle_status",
    "policy_id",
    "action",
    "decision",
    "deny_by_default",
    "linked_certification_records",
    "auth_inputs_ref",
    "required_certification_components",
    "required_support_refs",
    "support_judgment_refs",
    "aggregate_judgment_ref",
    "cex_closed_judgment_refs",
    "soundgap_refs",
    "scope_action_match",
    "required_human_assessment_roles",
    "required_tool_assessment_roles",
    "rollback_hooks_required",
    "expiry",
    "revocation_hooks",
    "tightening_conditions",
    "delegation_basis",
    "migration_witness_ref",
    "sandbox_required",
    "sandbox_status",
    "sandbox_waiver_residuals",
    "residual_gates",
    "ledger_event_refs",
    "provenance"
  ],
  "additionalProperties": false
}
