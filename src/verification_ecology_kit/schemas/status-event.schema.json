{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vet.example/schema/status-event.schema.json",
  "type": "object",
  "properties": {
    "status_event_id": { "type": "string" },
    "object_id": { "type": "string" },
    "pre_status": { "type": "string", "enum": ["active", "stale", "revoked", "migrated", "unknown"] },
    "post_status": { "type": "string", "enum": ["active", "stale", "revoked", "migrated", "unknown"] },
    "cause": { "type": "string" },
    "actor_authority_ref": { "type": "string" },
    "ledger_event_ref": { "type": "string" },
    "invalidation_trigger": { "type": "string" },
    "migration_target": { "type": "string" },
    "residual_disposition": { "type": "array", "items": { "type": "string" } },
    "predecessor_event_ref": { "type": ["string", "null"] },
    "provenance": { "type": "array", "items": { "type": "string" } }
  },
  "required": [
    "status_event_id",
    "object_id",
    "pre_status",
    "post_status",
    "cause",
    "actor_authority_ref",
    "ledger_event_ref",
    "invalidation_trigger",
    "migration_target",
    "residual_disposition",
    "predecessor_event_ref",
    "provenance"
  ],
  "additionalProperties": false
}
