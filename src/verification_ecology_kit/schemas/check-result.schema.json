{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vet.example/schema/check-result.schema.json",
  "type": "object",
  "properties": {
    "check_name": { "type": "string" },
    "result": {
      "type": "string",
      "enum": ["pass", "fail", "residualize", "quarantine", "not_checked"]
    },
    "failure_codes": { "type": "array", "items": { "type": "string" } },
    "residual_refs": { "type": "array", "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "suggested_repair_hooks": { "type": "array", "items": { "type": "string" } },
    "provenance": { "type": "array", "items": { "type": "string" } }
  },
  "required": [
    "check_name",
    "result",
    "failure_codes",
    "residual_refs",
    "evidence_refs",
    "suggested_repair_hooks",
    "provenance"
  ],
  "additionalProperties": false
}
