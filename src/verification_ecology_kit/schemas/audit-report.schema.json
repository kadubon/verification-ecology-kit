{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vet.example/schema/audit-report.schema.json",
  "type": "object",
  "properties": {
    "audit_name": { "type": "string" },
    "decision": { "type": "string", "enum": ["pass", "fail", "residualize", "quarantine", "not_checked"] },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "type": "string" },
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "suggested_repair_hooks": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["code", "message", "severity", "evidence_refs", "suggested_repair_hooks"],
        "additionalProperties": false
      }
    },
    "passed_checks": { "type": "array", "items": { "type": "string" } },
    "residualized_failures": { "type": "array", "items": { "type": "string" } },
    "support_blocking_failures": { "type": "array", "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "provenance": { "type": "array", "items": { "type": "string" } },
    "report_digest": { "type": "string" }
  },
  "required": [
    "audit_name",
    "decision",
    "findings",
    "passed_checks",
    "residualized_failures",
    "support_blocking_failures",
    "evidence_refs",
    "provenance",
    "report_digest"
  ],
  "additionalProperties": false
}
