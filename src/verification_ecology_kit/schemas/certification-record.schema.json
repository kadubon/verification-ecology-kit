{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vet.example/schema/certification-record.schema.json",
  "type": "object",
  "properties": {
    "certification_record_id": { "type": "string" },
    "object_id": { "type": "string" },
    "schema_version": { "type": "string" },
    "canonical_digest": { "type": "object" },
    "lifecycle_status": { "type": "string", "enum": ["active", "stale", "revoked", "migrated", "unknown"] },
    "stability_relation_id": { "type": "string" },
    "transition_policy_id": { "type": "string" },
    "declared_scope": { "type": "array", "items": { "type": "string" } },
    "declared_interval": { "type": "string" },
    "continuation_spec_ref": { "type": "string" },
    "packet_chain": { "type": "array", "items": { "type": "string" } },
    "certification_profile": { "type": "object" },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "reachability_certificate_refs": { "type": "array", "items": { "type": "string" } },
    "unsupported_assumptions": { "type": "array", "items": { "type": "string" } },
    "residual_obligations": { "type": "array", "items": { "type": "string" } },
    "provenance": { "type": "array", "items": { "type": "string" } }
  },
  "required": [
    "certification_record_id",
    "object_id",
    "schema_version",
    "canonical_digest",
    "lifecycle_status",
    "stability_relation_id",
    "transition_policy_id",
    "declared_scope",
    "declared_interval",
    "continuation_spec_ref",
    "packet_chain",
    "certification_profile",
    "evidence_refs",
    "reachability_certificate_refs",
    "unsupported_assumptions",
    "residual_obligations",
    "provenance"
  ],
  "additionalProperties": true
}
