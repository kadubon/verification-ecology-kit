{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vet.example/schema/judgment-record.schema.json",
  "type": "object",
  "properties": {
    "judgment_id": { "type": "string" },
    "judgment_kind": { "type": "string" },
    "subject": { "$ref": "vet-object-ref.schema.json" },
    "checker_or_policy_ref": { "type": "string" },
    "contract_version": { "type": "string" },
    "schema_version": { "type": "string" },
    "object_id": { "type": "string" },
    "canonical_digest": { "type": "object" },
    "use_context_ref": { "type": "string" },
    "canonical_input_ref": { "$ref": "vet-object-ref.schema.json" },
    "input_pointer": { "type": "string" },
    "input_digest": { "type": "object" },
    "digest_algorithm_id": { "type": "string" },
    "result": { "type": "string" },
    "jvalid_result": { "type": "string" },
    "status": { "type": "string", "enum": ["active", "stale", "revoked", "migrated", "unknown"] },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "residuals": { "type": "array", "items": { "type": "string" } },
    "provenance": { "type": "array", "items": { "type": "string" } },
    "timestamp_or_clock": { "type": "string" }
  },
  "required": [
    "judgment_id",
    "judgment_kind",
    "subject",
    "checker_or_policy_ref",
    "contract_version",
    "schema_version",
    "object_id",
    "canonical_digest",
    "use_context_ref",
    "canonical_input_ref",
    "input_pointer",
    "input_digest",
    "digest_algorithm_id",
    "result",
    "jvalid_result",
    "status",
    "assumptions",
    "evidence_refs",
    "residuals",
    "provenance",
    "timestamp_or_clock"
  ],
  "additionalProperties": false
}
