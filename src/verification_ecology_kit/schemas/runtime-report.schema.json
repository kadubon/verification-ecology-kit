{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vet.example/schema/runtime-report.schema.json",
  "type": "object",
  "properties": {
    "generated_packets": { "type": "array", "items": { "type": "string" } },
    "generated_from_residuals": { "type": "array", "items": { "type": "string" } },
    "inherited_residual_refs": { "type": "array", "items": { "type": "string" } },
    "inherited_boundary_refs": { "type": "array", "items": { "type": "string" } },
    "anti_overclosure_gaps": { "type": "array", "items": { "type": "string" } },
    "counter_packet_obligations": { "type": "array", "items": { "type": "string" } },
    "stages": { "type": "array", "items": { "$ref": "#/$defs/runtime_stage" } },
    "quarantine_decisions": { "$ref": "#/$defs/check_result_array" },
    "reachability_checks": { "$ref": "#/$defs/check_result_array" },
    "schema_checks": { "$ref": "#/$defs/check_result_array" },
    "lineage_checks": { "$ref": "#/$defs/check_result_array" },
    "repair_or_retire_decisions": { "$ref": "#/$defs/check_result_array" },
    "frontier_updates": { "$ref": "#/$defs/check_result_array" },
    "aperture_updates": { "$ref": "#/$defs/check_result_array" },
    "residuals_routed": { "type": "array", "items": { "type": "string" } },
    "quarantined_packets": { "type": "array", "items": { "type": "string" } },
    "aperture_debts": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } },
    "report_digest": { "type": "string" }
  },
  "required": [
    "generated_packets",
    "generated_from_residuals",
    "inherited_residual_refs",
    "inherited_boundary_refs",
    "anti_overclosure_gaps",
    "counter_packet_obligations",
    "stages",
    "quarantine_decisions",
    "reachability_checks",
    "schema_checks",
    "lineage_checks",
    "repair_or_retire_decisions",
    "frontier_updates",
    "aperture_updates",
    "residuals_routed",
    "quarantined_packets",
    "aperture_debts",
    "notes",
    "report_digest"
  ],
  "additionalProperties": false,
  "$defs": {
    "check_result_array": {
      "type": "array",
      "items": { "$ref": "check-result.schema.json" }
    },
    "runtime_stage": {
      "type": "object",
      "properties": {
        "stage_name": { "type": "string" },
        "packet_id": { "type": "string" },
        "check_result": { "$ref": "check-result.schema.json" },
        "decision": { "type": "string" },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "residual_refs": { "type": "array", "items": { "type": "string" } },
        "authority_effect": { "type": "string" },
        "notes": { "type": "array", "items": { "type": "string" } },
        "report_digest": { "type": "string" }
      },
      "required": [
        "stage_name",
        "packet_id",
        "check_result",
        "decision",
        "evidence_refs",
        "residual_refs",
        "authority_effect",
        "notes",
        "report_digest"
      ],
      "additionalProperties": false
    }
  }
}
